# Ignore macOS specific option on non-macOS systems
IgnoreUnknown UseKeychain

# Keep who you've connected to secret in case it gets leaked
HashKnownHosts yes

# Disable strict key checking on localhost connections and using /dev/null as the known hosts file
Host localhost
  UserKnownHostsFile /dev/null
  StrictHostKeyChecking no

# Use SSH over HTTPS port to defeat any ISP
# https://docs.github.com/en/authentication/troubleshooting-ssh/using-ssh-over-the-https-port
Host github.com
  Hostname ssh.github.com
  Port 443

# Allow multiple ssh keys for different GitHub accounts - e.g. ~/.ssh/keys/company.github.com
Host *.github.com
  Hostname ssh.github.com
  Port 443

Host remarkable
  Hostname 10.11.99.1
  User root

Host remarkable.lan
  User root

Host *
  IdentityFile ~/.ssh/keys/%n # Per-host key, e.g. ~/.ssh/keys/github.com or ~/.ssh/keys/company.github.com
  IdentityFile ~/.ssh/id_rsa # Fallback keys
  IdentitiesOnly yes # Don't send all keys to everyone
  AddKeysToAgent yes
  UseKeychain yes
